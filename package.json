{
  "name": "TechExactly",
  "version": "0.0.1",
  "private": true,
"scripts": {
  "android": "ENVFILE=.env.development react-native run-android",
  "android:staging": "ENVFILE=.env.staging react-native run-android",
  "android:prod": "ENVFILE=.env.production react-native run-android",

  "build:apk:dev": "cd android && ENVFILE=.env.development ./gradlew assembleDebug",
  "build:apk:staging": "cd android && ENVFILE=.env.staging ./gradlew assembleRelease",
  "build:apk:prod": "cd android && ENVFILE=.env.production ./gradlew assembleRelease",

  "build:aab:prod": "cd android && ENVFILE=.env.production ./gradlew bundleRelease",

  "start": "react-native start",
  "start:reset": "react-native start --reset-cache",
  "ios": "ENVFILE=.env.development react-native run-ios",
  "lint": "eslint .",
  "test": "jest"
},
  "dependencies": {
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-firebase/app": "^23.8.6",
    "@react-native-firebase/auth": "^23.8.6",
    "@react-native-firebase/firestore": "^23.8.6",
    "@react-native-firebase/messaging": "^23.8.6",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native/new-app-screen": "0.84.1",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@reduxjs/toolkit": "^2.11.2",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-config": "^1.6.1",
    "react-native-device-info": "^15.0.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-simple-toast": "^3.3.2",
    "react-native-svg": "^15.15.3",
    "react-native-toast-message": "^2.3.3",
    "react-native-uuid": "^2.0.3",
    "react-redux": "^9.2.0",
    "realm": "^20.2.0",
    "redux-logger": "^3.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
